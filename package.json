{
  "name": "ai-pm-cockpit",
  "version": "0.1.1",
  "description": "Aether - AI PM Cockpit",
  "main": "./out/main/index.js",
  "author": "TongWu021",
  "homepage": "https://github.com/TongWu021/aether",
  "repository": {
    "type": "git",
    "url": "https://github.com/TongWu021/aether.git"
  },
  "scripts": {
    "format": "prettier --write .",
    "lint": "eslint --cache .",
    "typecheck:node": "tsc --noEmit -p tsconfig.node.json --composite false",
    "typecheck:web": "tsc --noEmit -p tsconfig.web.json --composite false",
    "typecheck": "npm run typecheck:node && npm run typecheck:web",
    "start": "node scripts/run-electron-vite.mjs preview",
    "dev": "node scripts/run-electron-vite.mjs dev",
    "build": "npm run typecheck && electron-vite build",
    "postinstall": "electron-builder install-app-deps",
    "build:unpack": "npm run build && electron-builder --dir",
    "build:win": "npm run build && electron-builder --win",
    "build:mac": "electron-vite build && electron-builder --mac",
    "build:linux": "electron-vite build && electron-builder --linux",
    "release": "npm version patch -m 'chore: release v%s' && git push --follow-tags",
    "release:minor": "npm version minor -m 'chore: release v%s' && git push --follow-tags",
    "release:major": "npm version major -m 'chore: release v%s' && git push --follow-tags"
  },
  "dependencies": {
    "@electron-toolkit/preload": "^3.0.2",
    "@electron-toolkit/utils": "^4.0.0",
    "@fontsource-variable/jetbrains-mono": "^5.2.8",
    "@fontsource-variable/noto-sans-sc": "^5.2.10",
    "@fontsource-variable/space-grotesk": "^5.2.10",
    "@uiw/react-md-editor": "^4.0.11",
    "@univerjs/presets": "^0.21.1",
    "chokidar": "^4.0.3",
    "exceljs": "^4.4.0",
    "lucide-react": "^1.14.0",
    "papaparse": "^5.5.3",
    "react-markdown": "^10.1.0",
    "rehype-highlight": "^7.0.2",
    "remark-gfm": "^4.0.1"
  },
  "devDependencies": {
    "@electron-toolkit/eslint-config-prettier": "^3.0.0",
    "@electron-toolkit/eslint-config-ts": "^3.1.0",
    "@electron-toolkit/tsconfig": "^2.0.0",
    "@tailwindcss/vite": "^4.2.1",
    "@types/hast": "^3.0.4",
    "@types/node": "^22.19.1",
    "@types/papaparse": "^5.5.2",
    "@types/react": "^19.2.7",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^4.7.0",
    "electron": "^39.2.6",
    "electron-builder": "^26.0.12",
    "electron-vite": "^3.1.0",
    "eslint": "^9.39.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "prettier": "^3.7.4",
    "react": "^19.2.1",
    "react-dom": "^19.2.1",
    "react-refresh": "^0.17.0",
    "tailwindcss": "^4.2.1",
    "typescript": "^5.9.3",
    "vite": "^6.4.1"
  }
}
